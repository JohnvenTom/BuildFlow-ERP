# ============================================================
# BuildFlow ERP 后端环境变量示例配置
# ------------------------------------------------------------
# 使用说明：
#   1. 复制本文件为 .env：  cp .env.example .env
#   2. 按实际环境修改 .env 中的值
#   3. .env 文件已被 .gitignore 忽略，不会提交到仓库
#   4. 生产环境部署时，所有密钥务必更换为高强度随机值
# ============================================================

# 运行环境 (dev-开发 / test-测试 / prod-生产)
SPRING_PROFILES_ACTIVE=dev

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_NAME=buildflow_erp
DB_USERNAME=root
DB_PASSWORD=your_database_password_here

# JWT 配置（生产环境务必更换为32位以上的随机字符串）
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRATION=86400000

# 接口签名密钥
API_SIGN_SECRET=your_api_sign_secret_here
API_SIGN_TIMEOUT=300000

# Knife4j 文档配置（生产环境建议 KNIFE4J_PRODUCTION=true）
KNIFE4J_ENABLE=true
KNIFE4J_PRODUCTION=false

# 日志级别 (debug / info / warn / error)
LOG_LEVEL=info
