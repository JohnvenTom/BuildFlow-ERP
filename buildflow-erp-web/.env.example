# ============================================================
# BuildFlow ERP 前端环境变量示例配置
# ------------------------------------------------------------
# 使用说明：
#   1. 复制本文件为 .env.local：  cp .env.example .env.local
#   2. 按实际环境修改 .env.local 中的值
#   3. .env.local 已被 .gitignore 忽略，不会提交到仓库
#   4. Vite 优先级：.env.local > .env.[mode] > .env
# ============================================================

# 应用标题
VITE_APP_TITLE=BuildFlow ERP - 建材进销存CRM系统

# API 基础路径
VITE_API_BASE_URL=/api

# 后端服务地址（仅开发环境使用，用于 vite proxy）
VITE_API_TARGET=http://localhost:8080

# 应用端口
VITE_APP_PORT=3000

# 是否启用 Mock 数据
VITE_USE_MOCK=false

# Token 存储键名
VITE_TOKEN_KEY=buildflow_token
